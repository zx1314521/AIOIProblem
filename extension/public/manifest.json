{
  "manifest_version": 3,
  "name": "AIOIProblem OJ Importer",
  "version": "0.1.0",
  "description": "Scan supported OJ problem and submission pages into AIOIProblem.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://codeforces.com/*",
    "https://atcoder.jp/*",
    "https://www.luogu.com.cn/*",
    "https://ac.nowcoder.com/*",
    "https://vjudge.net/*"
  ],
  "action": {
    "default_title": "AIOI OJ Import",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://codeforces.com/*",
        "https://atcoder.jp/*",
        "https://www.luogu.com.cn/*",
        "https://ac.nowcoder.com/*",
        "https://vjudge.net/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
