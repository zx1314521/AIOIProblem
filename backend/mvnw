#!/bin/sh
set -e
if [ ! -f ".mvn/wrapper/maven-wrapper.jar" ]; then
  if command -v mvn >/dev/null 2>&1; then
    exec mvn "$@"
  fi
  mkdir -p .mvn/wrapper
  curl -fsSL -o .mvn/wrapper/maven-wrapper.jar https://repo.maven.apache.org/maven2/org/apache/maven/wrapper/maven-wrapper/3.3.2/maven-wrapper-3.3.2.jar
fi
exec java -jar .mvn/wrapper/maven-wrapper.jar "$@"
